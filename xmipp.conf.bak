[BUILD]
CC=/opt/homebrew/bin/gcc-13
CCFLAGS=
CONFIG_VERSION=6abef56c4ddf26871ee6c57a5714882d579b7b9b
CUDA=False
CXX=/opt/homebrew/bin/g++-13
CXXFLAGS= -mtune=native -march=native -flto -std=c++17 -O3
CXX_CUDA=
DEBUG=False
INCDIRFLAGS=-I../ -I/Users/miceta/miniconda3/envs/scipion3/include -I/opt/homebrew/include -I/opt/homebrew/opt/fftw/include -I/opt/homebrew/opt/libtiff/include
JAR=%(JAVA_BINDIR)s/jar
JAVAC=%(JAVA_BINDIR)s/javac
JAVA_BINDIR=%(JAVA_HOME)s/bin
JAVA_HOME=/opt/homebrew/opt/openjdk
JNI_CPPPATH=%(JAVA_HOME)s/include:%(JAVA_HOME)s/include/linux
LIBDIRFLAGS=-L/Users/miceta/miniconda3/envs/scipion3/lib -L/opt/homebrew/lib -L/opt/homebrew/opt/fftw/lib -L/opt/homebrew/opt/libtiff/lib
LINKERFORPROGRAMS=g++-13
LINKFLAGS=-flto
MATLAB=False
MATLAB_DIR=
MPI_CC=mpicc
MPI_CXX=mpicxx
MPI_CXXFLAGS= -L/opt/homebrew/Cellar/open-mpi/5.0.0/lib -I/opt/homebrew/Cellar/open-mpi/5.0.0/include
MPI_LINKERFORPROGRAMS=mpicxx
MPI_LINKFLAGS=
MPI_RUN=mpirun
OMPI_CC=gcc-13
OMPI_CXX=g++-13
NVCC=
NVCC_CXXFLAGS=
NVCC_LINKFLAGS=
OPENCV=False
OPENCVSUPPORTSCUDA=
OPENCV_VERSION=
PYTHONINCFLAGS=-I/Users/miceta/miniconda3/envs/scipion3/include/python3.8 -I/Users/miceta/miniconda3/envs/scipion3/lib/python3.8/site-packages/numpy/core/include
PYTHON_LIB=python3.8
STARPU=False
STARPU_HOME=
STARPU_INCLUDE=%(STARPU_HOME)s/include/starpu/1.3
STARPU_LIB=%(STARPU_HOME)s/lib
STARPU_LIBRARY=libstarpu-1.3
USE_DL=False
VERIFIED=False
